JELLYFIN_HOST=https://your-jellyfin-server.com
JELLYFIN_USERNAME=your-jellyfin-username
JELLYFIN_PASSWORD=your-jellyfin-password

# Optional (have defaults)
AUDIO_BITRATE=192000
VIDEO_BITRATE=5000000
MAX_AUDIO_CHANNELS=2
MAX_HEIGHT=1080
MAX_WIDTH=1920

# Cast Device Configuration
INSTANCE_NAME=VRChat Jellyfin Player
WEBSERVER_PORT=4000

# HLS Configuration (optional)
HLS_SEGMENT_DURATION=2
HLS_MAX_SEGMENTS=10

# Sync Configuration (optional)
SYNC_HEARTBEAT_TIMEOUT=30000
SYNC_TOLERANCE=2000
